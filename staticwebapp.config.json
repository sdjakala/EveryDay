{  
  "platform": {
    "apiRuntime": "node:20"
  },
  "routes": [
    {
      "route": "/sw.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "responseOverrides": {
    "404": {
        "rewrite": "/404"
    }
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}